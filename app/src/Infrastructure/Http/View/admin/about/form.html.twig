{% extends 'admin/layout.html.twig' %}

{% block title %}Sobre mí{% endblock %}

{% block content %}
    <div class="admin-page-header">
        <h1>Sobre mí</h1>
    </div>

    <form method="post"
          action="{{ path('admin_about_update') }}"
          enctype="multipart/form-data"
          class="admin-form">

        <div class="form-group">
            <label for="content">Texto biográfico</label>
            <textarea id="content" name="content" rows="12">{{ page is not null and page.content is not null ? page.content : '' }}</textarea>
            <small>Puedes usar HTML básico.</small>
        </div>

        <div class="form-group">
            <label>Foto</label>
            {% if page is not null and page.photoFilename is not null %}
            <div class="current-image">
                <img src="/uploads/about/{{ page.photoFilename }}" alt="Foto actual">
                <label class="checkbox-label">
                    <input type="checkbox" name="removePhoto" value="1">
                    Eliminar foto actual
                </label>
            </div>
            {% endif %}
            <input type="file" name="photoFile" accept="image/jpeg,image/png,image/webp">
            <small>Sube una nueva foto para reemplazar la actual.</small>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn--primary">Guardar cambios</button>
        </div>
    </form>
{% endblock %}
