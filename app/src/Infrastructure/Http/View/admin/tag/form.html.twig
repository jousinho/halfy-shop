{% extends 'admin/layout.html.twig' %}

{% block title %}{{ tag is null ? 'Nuevo tag' : 'Editar tag' }}{% endblock %}

{% block content %}
    <div class="admin-page-header">
        <h1>{{ tag is null ? 'Nuevo tag' : 'Editar: ' ~ tag.name.value }}</h1>
        <a href="{{ path('admin_tags') }}" class="btn btn--secondary">← Volver</a>
    </div>

    <form method="post"
          action="{{ tag is null ? path('admin_tags_create') : path('admin_tags_update', {id: tag.id.value}) }}"
          class="admin-form">

        <div class="form-group">
            <label for="name">Nombre *</label>
            <input type="text" id="name" name="name" required
                   value="{{ tag is not null ? tag.name.value : '' }}">
        </div>

        <div class="form-group">
            <label for="slug">Slug *</label>
            <input type="text" id="slug" name="slug" required
                   placeholder="ej. abstracto"
                   value="{{ tag is not null ? tag.slug : '' }}">
            <small>Solo minúsculas y guiones.</small>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn--primary">
                {{ tag is null ? 'Crear tag' : 'Guardar cambios' }}
            </button>
        </div>
    </form>
{% endblock %}
