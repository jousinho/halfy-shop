<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — HalfyShop</title>
    <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body class="admin-body admin-body--login">

    <div class="login-box">
        <h1 class="login-title">HalfyShop</h1>

        {% if error %}
            <div class="flash flash--error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" action="{{ path('admin_login') }}" class="login-form">
            <div class="form-group">
                <label for="username">Usuario</label>
                <input type="text" id="username" name="_username" autocomplete="username"
                       value="{{ last_username }}" required autofocus>
            </div>
            <div class="form-group">
                <label for="password">Contraseña</label>
                <input type="password" id="password" name="_password" autocomplete="current-password" required>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <div class="form-actions">
                <button type="submit" class="btn btn--primary btn--full">Entrar</button>
            </div>
        </form>
    </div>

</body>
</html>
